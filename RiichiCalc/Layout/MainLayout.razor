@inherits LayoutComponentBase
@inject LanguageService Lang
@inject LocalStorageService Storage
@implements IDisposable

<div class="app-shell">
    <div class="app-card">
        <header class="app-header">
            <h1 class="app-title"><i class="bi bi-calculator-fill me-2"></i>@Lang.Get("RiichiCalculator")</h1>
            <div class="lang-toggle">
                @foreach (var lang in LanguageService.SupportedLanguages)
                {
                    var l = lang;
                    <button type="button" class="lang-btn @(Lang.Language == l ? "active" : "")"
                            @onclick="() => SetLanguage(l)">@l.ToUpperInvariant()</button>
                }
            </div>
        </header>
        <main class="app-body">
            @Body
        </main>
    </div>
</div>

@code {
    // The shared LanguageService has no persistence; this dedicated app stores the toggle
    // choice itself. English is the default for the standalone calculator (≠ the club default).
    private const string LangKey = "riichicalc.lang";

    protected override async Task OnInitializedAsync()
    {
        Lang.OnLanguageChanged += StateHasChanged;
        var stored = await Storage.GetAsync<string>(LangKey);
        Lang.SetLanguage(string.IsNullOrEmpty(stored) ? "en" : stored);
    }

    private async Task SetLanguage(string lang)
    {
        Lang.SetLanguage(lang);
        await Storage.SetAsync(LangKey, lang);
    }

    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}
